{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Agents Desktop",
  "version": "0.1.0",
  "identifier": "com.safeai613.agents",
  "build": {
    "beforeDevCommand": "npm --prefix ../../client run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix ../../client run build",
    "frontendDist": "../../client/dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Agents Desktop",
        "width": 1100,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8000 ws://localhost:8000; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/agents-core"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
