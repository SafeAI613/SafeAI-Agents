{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window capabilities: run the bundled Python core as a sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/agents-core", "sidecar": true, "args": true }
      ]
    }
  ]
}
